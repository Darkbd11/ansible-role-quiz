# ============================================================
# Fichier de configuration genere automatiquement par Ansible
# Role    : {{ quiz_role_author }}
# App     : {{ quiz_app_name }}
# Machine : {{ ansible_hostname }}
# Date    : {{ ansible_date_time.date }}
# ============================================================

# Port d'ecoute de l'application
PORT={{ quiz_app_port }}

# Environnement d'execution
NODE_ENV={{ quiz_node_env }}

# URL de base de l'application
APP_URL=http://{{ ansible_default_ipv4.address }}:{{ quiz_app_port }}

# Nom de l'application
APP_NAME={{ quiz_app_name }}

# Version de Node.js utilisee
NODE_VERSION={{ quiz_node_version }}
